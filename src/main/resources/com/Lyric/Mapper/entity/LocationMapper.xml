<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lyric.lyric.Mapper.entity.LocationMapper">
    
    <!-- 结果映射 -->
    <resultMap id="locationResultMap" type="com.lyric.lyric.Pojo.entity.LocationPojo">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="alias" column="alias"/>
        <result property="longitude" column="longitude"/>
        <result property="latitude" column="latitude"/>
        <result property="city" column="city"/>
        <result property="geoHash" column="geo_hash"/>
        <result property="firstAppearance" column="first_appearance"/>
        <result property="lastAppearance" column="last_appearance"/>
        <result property="appearanceCount" column="appearance_count"/>
        <result property="importance" column="importance"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    
    <!-- 插入地点 -->
    <insert id="insert" parameterType="com.lyric.lyric.Pojo.entity.LocationPojo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO location(name, alias, longitude, latitude, city, geo_hash, first_appearance, last_appearance, appearance_count, importance)
        VALUES(#{name}, #{alias}, #{longitude}, #{latitude}, #{city}, #{geoHash}, #{firstAppearance}, #{lastAppearance}, #{appearanceCount}, #{importance})
    </insert>
    
    <!-- 根据ID查询地点 -->
    <select id="selectById" parameterType="long" resultMap="locationResultMap">
        SELECT * FROM location WHERE id = #{id}
    </select>
    
    <!-- 查询所有地点 -->
    <select id="selectAll" resultMap="locationResultMap">
        SELECT * FROM location
    </select>
    
    <!-- 更新地点 -->
    <update id="update" parameterType="com.lyric.lyric.Pojo.entity.LocationPojo">
        UPDATE location
        SET name=#{name}, alias=#{alias}, longitude=#{longitude}, latitude=#{latitude},
            city=#{city}, geo_hash=#{geoHash}, first_appearance=#{firstAppearance}, 
            last_appearance=#{lastAppearance}, appearance_count=#{appearanceCount},
            importance=#{importance}
        WHERE id=#{id}
    </update>
    
    <!-- 根据ID删除地点 -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM location WHERE id = #{id}
    </delete>
    
</mapper>