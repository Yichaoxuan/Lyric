<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lyric.lyric.Mapper.relation.DiaryTagMapper">
    
    <!-- 结果映射 -->
    <resultMap id="diaryTagResultMap" type="com.lyric.lyric.Pojo.relation.DiaryTagPojo">
        <id property="id" column="id"/>
        <result property="diaryId" column="diary_id"/>
        <result property="tagId" column="tag_id"/>
        <result property="confidence" column="confidence"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    
    <!-- 插入日记-标签关联 -->
    <insert id="insert" parameterType="com.lyric.lyric.Pojo.relation.DiaryTagPojo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO diary_tag(diary_id, tag_id, confidence)
        VALUES(#{diaryId}, #{tagId}, #{confidence})
    </insert>
    
    <!-- 根据ID查询日记-标签关联 -->
    <select id="selectById" parameterType="long" resultMap="diaryTagResultMap">
        SELECT * FROM diary_tag WHERE id = #{id}
    </select>
    
    <!-- 根据日记ID查询所有关联的标签 -->
    <select id="selectByDiaryId" parameterType="long" resultMap="diaryTagResultMap">
        SELECT * FROM diary_tag WHERE diary_id = #{diaryId}
    </select>
    
    <!-- 查询所有日记-标签关联 -->
    <select id="selectAll" resultMap="diaryTagResultMap">
        SELECT * FROM diary_tag
    </select>
    
    <!-- 更新日记-标签关联 -->
    <update id="update" parameterType="com.lyric.lyric.Pojo.relation.DiaryTagPojo">
        UPDATE diary_tag
        SET diary_id=#{diaryId}, tag_id=#{tagId}, confidence=#{confidence}
        WHERE id=#{id}
    </update>
    
    <!-- 根据ID删除日记-标签关联 -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM diary_tag WHERE id = #{id}
    </delete>
    
    <!-- 根据日记ID和标签ID删除关联记录 -->
    <delete id="deleteByDiaryIdAndTagId">
        DELETE FROM diary_tag WHERE diary_id = #{diaryId} AND tag_id = #{tagId}
    </delete>
    
</mapper>