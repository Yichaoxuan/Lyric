<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lyric.lyric.Mapper.relation.EventPersonMapper">
    
    <!-- 结果映射 -->
    <resultMap id="eventPersonResultMap" type="com.lyric.lyric.Pojo.relation.EventPersonPojo">
        <id property="id" column="id"/>
        <result property="eventId" column="event_id"/>
        <result property="personId" column="person_id"/>
        <result property="role" column="role"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    
    <!-- 插入事件-人物关联 -->
    <insert id="insert" parameterType="com.lyric.lyric.Pojo.relation.EventPersonPojo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO event_person(event_id, person_id, role)
        VALUES(#{eventId}, #{personId}, #{role})
    </insert>
    
    <!-- 根据ID查询事件-人物关联 -->
    <select id="selectById" parameterType="long" resultMap="eventPersonResultMap">
        SELECT * FROM event_person WHERE id = #{id}
    </select>
    
    <!-- 根据事件ID查询所有关联的人物 -->
    <select id="selectByEventId" parameterType="long" resultMap="eventPersonResultMap">
        SELECT * FROM event_person WHERE event_id = #{eventId}
    </select>
    
    <!-- 查询所有事件-人物关联 -->
    <select id="selectAll" resultMap="eventPersonResultMap">
        SELECT * FROM event_person
    </select>
    
    <!-- 更新事件-人物关联 -->
    <update id="update" parameterType="com.lyric.lyric.Pojo.relation.EventPersonPojo">
        UPDATE event_person
        SET event_id=#{eventId}, person_id=#{personId}, role=#{role}
        WHERE id=#{id}
    </update>
    
    <!-- 根据ID删除事件-人物关联 -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM event_person WHERE id = #{id}
    </delete>
    
    <!-- 根据事件ID和人物ID删除关联记录 -->
    <delete id="deleteByEventIdAndPersonId">
        DELETE FROM event_person WHERE event_id = #{eventId} AND person_id = #{personId}
    </delete>
    
</mapper>